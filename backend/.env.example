# Backend Environment Variables for Fly.io
# Set these using: fly secrets set KEY=value

# Your Vercel frontend URL (for CORS)
APP_URL=https://syncwave.vercel.app

# YouTube Data API v3 Key
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Do NOT set PORT here — Fly.io sets it automatically via fly.toml
